{
  "manifest_version": 3,
  "name": "Aleph — Context Capture",
  "version": "1.0.0",
  "description": "Captures browsing activity and sends it to Aleph's local context store.",
  "permissions": [
    "tabs",
    "bookmarks",
    "history",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:2198/*",
    "http://localhost:2198/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aleph"
  },
  "icons": {
    "48": "icon.png"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aleph@nomeda.dev",
      "strict_min_version": "109.0"
    }
  }
}
